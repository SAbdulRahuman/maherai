# Maher AI — QuantOps — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ─── Market Data ─────────────────────────────────────────
NSE_API_BASE_URL=https://api.example.com
NSE_API_RATE_LIMIT=5

# ─── AI Engine ───────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=sk-change-me
MAHER_CONFIDENCE_THRESHOLD=60

# ─── Database ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maherai
POSTGRES_USER=maherai
POSTGRES_PASSWORD=changeme

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Observability ───────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3100

# ─── API ─────────────────────────────────────────────────
API_PORT=8000
API_KEY_PREFIX=mhr_
JWT_SECRET=changeme-use-strong-secret
CORS_ORIGINS=http://localhost:3001

# ─── Dashboard ───────────────────────────────────────────
DASHBOARD_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
